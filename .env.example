# Copy to .env for local overrides — .env is gitignored and is the ONLY place
# real secrets belong. Everything here is a fake/default reference value.

# Public URLs baked into the built site (defaults = production).
# The orchestrator (npm run start:dev / start:prod) overrides these
# automatically to point at locally running apps.
PUBLIC_KINEGRAM_URL=https://kinegram.3m4.net
PUBLIC_BUBBLES_URL=https://bubbles.3m4.net
PUBLIC_SHORTENER_URL=https://3m4.net
SITE_URL=https://info.3m4.net

# Orchestrator port overrides (defaults live in apps.yaml).
#INFO_DEV_PORT=4321
#KINEGRAM_DEV_PORT=4322
#BUBBLES_DEV_PORT=4323
#BUBBLES_CLASSIC_DEV_PORT=8015
#INFO_PROD_PORT=8080
#KINEGRAM_PROD_PORT=8081
#BUBBLES_PROD_PORT=8082

# Example secret (fake). Real keys go in .env only, never committed.
#SOME_API_KEY=fake-api-key-123
